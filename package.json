        "dotenv": "^16.0.1",
        "express": "^4.19.2",
        "express-rate-limit": "^6.7.0",
        "jsdom": "^28.1.0",
        "jsonwebtoken": "^9.0.0",
        "mongodb": "^6.17.0",
        "morgan": "^1.10.0",
        "nodemailer": "^8.0.4",
        "qb-answer-checker": "^1.1.9",
        "stripe": "^12.10.0",
        "uuid": "^8.3.2",
        "ws": "^8.8.0"
    },
    "devDependencies": {
        "@babel/core": "^7.29.0",
        "@babel/preset-react": "^7.28.5",
        "babel-loader": "^10.1.1",
        "sass": "^1.56.2",
        "semistandard": "^17.0.0",
